NODE_ENV=development
PORT=3001

# PostgreSQL (docker-compose)
DATABASE_URL=postgresql://green_angels:green_angels@localhost:5432/green_angels?schema=public

# Redis (docker-compose, для BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Той самий секрет, що й AUTH_SESSION_SECRET у green-angels-shop (мін. 32 символи)
JWT_SECRET=dev-only-green-angels-session-secret-min-32-chars!!

# Next.js dev server
CORS_ORIGIN=http://localhost:3000
